# RabbitMQ connection
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Groq API key for Whisper transcription
GROQ_API_KEY=your_groq_api_key_here

# RapidAPI key(s) for YouTube audio downloader
# Prefer RAPIDAPI_KEYS for key rotation (comma-separated)
RAPIDAPI_KEYS=your_rapidapi_key_1,your_rapidapi_key_2

# Alternative single-key format (use this if you only have one key)
# RAPIDAPI_KEY=your_rapidapi_key_here

# Alternative JSON array format for multiple keys
# RAPIDAPI_KEYS=["your_rapidapi_key_1","your_rapidapi_key_2"]